   :body "use core::hash::{BuildHasher as _, Hash};\n\n#[doc(hidden)]\npub fn hash<V: Hash>(value: &V) -> usize {\n    foldhash::quality::FixedState::default().hash_one(value) as usize\n}\n"} {:path "src/rust_vec.rs"
